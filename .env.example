# === Required (all components) ===
MONGODB_URI=
MONGODB_USER=
MONGODB_PASS=
MONGODB_CLUSTERNAME=

# === API server (runs on host, manages Docker containers) ===
# Set to localhost — API connects to Redis via host port mapping
REDIS_HOST=localhost
# REDIS_PORT=6379
# API_KEY=                    # Set to require x-api-key header on mutating endpoints
# CORS_ORIGINS=http://localhost:5173,http://localhost:8000

# === ClickHouse (optional — for replay mode with historical data) ===
# CLICKHOUSE_HOST=localhost
# CLICKHOUSE_PORT=8123
# CLICKHOUSE_DB=eontrading

# === Price lookup ===
# PRICE_SOURCE=yfinance
# PRICE_TIMEOUT=15

# === News sources (optional — enables extra sources in Watcher) ===
# PERSIST_NEWS=1              # Save fetched news to MongoDB for later backtest/replay
# COLLECT_ONLY=1              # Only collect news to DB, don't publish to trading pipeline
NEWSAPI_KEY=
FINNHUB_KEY=
TWITTER_BEARER_TOKEN=

# === Analyzer (optional — default: keyword) ===
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
#
# Azure OpenAI:
#   OPENAI_BASE_URL=https://your-resource.openai.azure.com/openai/deployments/your-deployment
#   OPENAI_MODEL=gpt-4o-mini
#   OPENAI_API_VERSION=2024-08-01-preview
#
# Local Ollama:
#   OPENAI_BASE_URL=http://localhost:11434/v1
#   OPENAI_MODEL=llama3
#   OPENAI_API_KEY=ollama

# === Broker (optional — default: log/dry-run) ===
# Options: log, futu, ibkr, alpaca
BROKER=log

# Trading parameters (defaults shown)
# THRESHOLD=0.4
# MIN_CONFIDENCE=0.15
# MAX_ALLOCATION=0.2
# STOP_LOSS_PCT=0.05
# TAKE_PROFIT_PCT=0.10
# SL_CHECK_INTERVAL=60

# Alpaca (if BROKER=alpaca)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# Futu (if BROKER=futu)
# FUTU_LIVE=1
# FUTU_REAL=1
