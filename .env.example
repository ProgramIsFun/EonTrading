# === Required (all components) ===
MONGODB_URI=
MONGODB_USER=
MONGODB_PASS=
MONGODB_CLUSTERNAME=

# === API server (runs on host, manages Docker containers) ===
# Set to localhost — API connects to Redis via host port mapping
REDIS_HOST=localhost
# REDIS_PORT=6379

# === ClickHouse (optional — for replay mode with historical data) ===
# CLICKHOUSE_HOST=localhost
# CLICKHOUSE_PORT=8123
# CLICKHOUSE_DB=eontrading

# === Price lookup ===
# PRICE_SOURCE=yfinance
# PRICE_TIMEOUT=15

# === News sources (optional — enables extra sources in Watcher) ===
NEWSAPI_KEY=
FINNHUB_KEY=
TWITTER_BEARER_TOKEN=

# === Analyzer (optional — default: keyword) ===
OPENAI_API_KEY=

# === Broker (optional — default: log/dry-run) ===
# Options: log, futu, ibkr, alpaca
BROKER=log

# Alpaca (if BROKER=alpaca)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# Futu (if BROKER=futu)
# FUTU_LIVE=1
# FUTU_REAL=1
