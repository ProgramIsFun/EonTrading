# EonTrading — single .env file
# Copy to .env and fill in your values.

# === MongoDB (required) ===
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net
MONGODB_USER=
MONGODB_PASS=
MONGODB_CLUSTERNAME=

# === Redis (optional — only for distributed mode) ===
REDIS_HOST=localhost
# REDIS_PORT=6379

# === News sources (pick what you need) ===
NEWSAPI_KEY=
FINNHUB_KEY=
TWITTER_BEARER_TOKEN=
# PERSIST_NEWS=1
# PUBLISH_PIPELINE=1

# === Sentiment analyzer (default: keyword, free) ===
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# === Broker (default: paper/log, no API key needed) ===
BROKER=log
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# === Trading parameters (defaults shown) ===
# THRESHOLD=0.4
# MIN_CONFIDENCE=0.15
# MAX_ALLOCATION=0.2
# STOP_LOSS_PCT=0.05
# TAKE_PROFIT_PCT=0.10
